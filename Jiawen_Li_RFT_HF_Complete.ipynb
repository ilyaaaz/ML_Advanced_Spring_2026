    "def format_for_training(df):\n",
    "    def fmt(examples):\n",
    "        return {'text': [f\"{p}\\n{r}\" for p, r in zip(examples['prompt'], examples['response'])]}\n",
    "    ds = Dataset.from_pandas(df)\n",
    "    return ds.map(fmt, batched=True).select_columns(['text'])\n",
    "\n",
    "hard_ds = format_for_training(hard_data)\n",
