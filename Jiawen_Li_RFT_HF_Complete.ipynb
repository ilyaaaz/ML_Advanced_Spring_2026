    "        # High vol scenarios\n",
    "        {'S': 100, 'K': 100, 'T': 1.0, 'r': 0.03, 'sigma': 0.5},\n",
    "        # Very short term\n",
    "        {'S': 100, 'K': 105, 'T': 0.01, 'r': 0.02, 'sigma': 0.2},\n",
    "        # Very long term\n",
    "        {'S': 100, 'K': 100, 'T': 5.0, 'r': 0.03, 'sigma': 0.15},\n",
    "    ]\n",
    "    \n",
    "    for _ in range(n):\n",
    "        case = edge_cases[_ % len(edge_cases)]\n",
    "        opt_type = 'call' if _ % 2 == 0 else 'put'\n",
    "        \n",
    "        prompt = f\"Edge case: Price {opt_type} with S={case['S']}, K={case['K']}, T={case['T']}, r={case['r']*100}%, sigma={case['sigma']*100}%\"\n",
    "        response = f\"<tool_code>bs(S={case['S']}, K={case['K']}, T={case['T']}, r={case['r']}, sigma={case['sigma']}, type=\\\"{opt_type}\\\")</tool_code>\"\n",
    "        \n",
    "        data.append({'prompt': prompt, 'response': response})\n",
    "    \n",
    "    return pd.DataFrame(data)\n",
