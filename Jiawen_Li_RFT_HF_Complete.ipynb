    "def generate_hard_examples(n=30):\n",
    "    \"\"\"Generate edge case / harder option pricing problems.\"\"\"\n",
    "    data = []\n",
    "    \n",
    "    # Edge cases\n",
    "    edge_cases = [\n",
    "        # Deep ITM calls\n",
    "        {'S': 150, 'K': 100, 'T': 0.1, 'r': 0.02, 'sigma': 0.1},\n",
