    "    \n",
    "    for idx, row in unseen_df.iterrows():\n",
    "        prompt = row['prompt']\n",
    "        inputs = tokenizer(prompt, return_tensors='pt', truncation=True, max_length=256)\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            outputs = model.generate(inputs['input_ids'], max_length=200, temperature=0.5)\n",
    "        \n",
    "        response = tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
    "        \n",
    "        # Check if tool was called\n",
    "        if '<tool_code>' in response and 'bs(' in response:\n",
    "            correct_tool_calls += 1\n",
    "            \n",
    "            # Check format\n",
    "            if all(param in response for param in ['S=', 'K=', 'T=', 'r=', 'sigma=']):\n",
    "                correct_format += 1\n",
    "    \n",
    "    generalization_results[model_name] = {\n",
    "        'tool_call_rate': correct_tool_calls / len(unseen_df) * 100,\n",
    "        'format_rate': correct_format / len(unseen_df) * 100,\n",
    "    }\n",
    "\n",
    "# Results table\n",
    "print(f'\\nGeneralization to Unseen Parameters:')\n",
    "print(f'{'Model':<12} {'Tool Call Rate':<20} {'Format Accuracy':<20}')\n",
    "print('-'*50)\n",
    "\n",
    "for model_name, results in generalization_results.items():\n",
    "    print(f'{model_name:<12} {results[\"tool_call_rate\"]:>6.1f}% {\"\":<12} {results[\"format_rate\"]:>6.1f}%')\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "models = list(generalization_results.keys())\n",
    "tool_rates = [generalization_results[m]['tool_call_rate'] for m in models]\n",
    "format_rates = [generalization_results[m]['format_rate'] for m in models]\n",
    "\n",
    "x = np.arange(len(models))\n",
    "width = 0.35\n",
    "\n",
    "ax.bar(x - width/2, tool_rates, width, label='Tool Call Rate', color='#3498db')\n",
    "ax.bar(x + width/2, format_rates, width, label='Format Accuracy', color='#2ecc71')\n",
    "ax.set_ylabel('Percentage (%)')\n",
    "ax.set_title('Generalization to Unseen Parameter Values')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(models)\n",
    "ax.legend()\n",
    "ax.set_ylim([0, 120])\n",
    "\n",
    "for i, v in enumerate(tool_rates):\n",
    "    ax.text(i - width/2, v + 3, f'{v:.0f}%', ha='center', fontsize=10, fontweight='bold')\n",
    "for i, v in enumerate(format_rates):\n",
    "    ax.text(i + width/2, v + 3, f'{v:.0f}%', ha='center', fontsize=10, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('generalization_unseen_params.png', dpi=100, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f'✓ Generalization analysis complete')"
   ]
