    "    seed=42,\n",
    "    report_to=[],\n",
    "    max_seq_length=512,\n",
    "    dataset_text_field='text',\n",
    ")\n",
    "\n",
    "continued_trainer = SFTTrainer(\n",
    "    model=continued_model,\n",
    "    args=continued_config,\n",
    "    train_dataset=hard_ds,\n",
    "    tokenizer=tokenizer,\n",
